# dock_guard 环境变量模板 (复制为 .env, 填入真实值, 不入仓)
# 详见设计文档 §15.7

# ─── MQTT broker (必填) ─────────────────────────────────────────────
MQTT_BROKER_URL=ssl://broker.example.com:8883
MQTT_USERNAME=dock_guard
MQTT_PASSWORD=replace-me
MQTT_DOCK_SN=<your-dock-sn>             # sim 录制样本: 8UUXN7N00A0GAA

# ─── HTTP /admin/* 鉴权 (必填) ───────────────────────────────────────
# 生成: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_TOKEN=replace-me-with-random-hex

# ─── 钉钉机器人 (用钉钉时必填) ────────────────────────────────────────
# 在钉钉群"群设置→机器人"创建自定义机器人, 选"加签"安全模式
DINGTALK_BOT_WEBHOOK_PRIMARY=https://oapi.dingtalk.com/robot/send?access_token=replace-me
DINGTALK_BOT_SECRET_PRIMARY=replace-me-with-dingtalk-sign-secret

# ─── Webhook (用 webhook 时按 endpoint id 配) ────────────────────────
# WEBHOOK_SECRET_<endpoint_id> 与 webhooks.yaml 里的 id 字段对应
WEBHOOK_SECRET_OPS=replace-me-with-hmac-secret
